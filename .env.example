############################################
# Artpulse environment template
# Copy to .env.local for local development.
# Never commit .env.local or secret-bearing .env files.
############################################

##############################
# Core app / database
##############################
# PostgreSQL only (no SQLite production mode).
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>?schema=public"
# Optional Prisma direct connection string.
DIRECT_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>?schema=public"

##############################
# Auth.js / NextAuth
##############################
# Keep AUTH_SECRET and NEXTAUTH_SECRET identical.
AUTH_SECRET="<AUTH_SECRET>"
NEXTAUTH_SECRET="<AUTH_SECRET>"
NEXTAUTH_URL="http://localhost:3000"

##############################
# Public URL configuration
##############################
# Canonical public app URL used in generated links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

##############################
# OAuth providers (optional)
##############################
AUTH_GOOGLE_ID="<GOOGLE_OAUTH_CLIENT_ID>"
AUTH_GOOGLE_SECRET="<GOOGLE_OAUTH_CLIENT_SECRET>"

##############################
# Admin access policy
##############################
ADMIN_EMAILS="admin@example.com"
ADMIN_EMAIL_DOMAINS="example.com"

##############################
# Geocoding
##############################
# mapbox (default) or google
GEOCODER_PROVIDER="mapbox"
# Required when GEOCODER_PROVIDER=google
GOOGLE_MAPS_API_KEY="<GOOGLE_MAPS_API_KEY>"
# Optional public client token aliases (non-secret). Use only if client map features require them.
NEXT_PUBLIC_MAPBOX_TOKEN=""
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""
# Optional server-side token for Mapbox API requests.
MAPBOX_ACCESS_TOKEN="<MAPBOX_ACCESS_TOKEN>"

##############################
# Scheduled jobs and ops security
##############################
CRON_SECRET="<CRON_SHARED_SECRET>"
OPS_SECRET="<OPS_BEARER_SECRET>"
ANALYTICS_SALT="<ANALYTICS_SALT>"

##############################
# Redis (recommended local, required production)
##############################
UPSTASH_REDIS_REST_URL="<UPSTASH_REDIS_REST_URL>"
UPSTASH_REDIS_REST_TOKEN="<UPSTASH_REDIS_REST_TOKEN>"

##############################
# Rate limit tuning (optional)
##############################
RATE_LIMIT_ANALYTICS_VIEW_WRITE_PER_MINUTE="120"
RATE_LIMIT_ANALYTICS_VIEW_WRITE_WINDOW_MS="60000"

##############################
# Editorial notifications (optional)
##############################
EDITORIAL_NOTIFICATIONS_WEBHOOK_URL="<EDITORIAL_WEBHOOK_URL>"
EDITORIAL_NOTIFY_TO="ops@example.com"
EDITORIAL_NOTIFICATIONS_EMAIL_ENABLED="false"

##############################
# AI ingest / enrichment
##############################
AI_INGEST_ENABLED="0"
OPENAI_API_KEY="<OPENAI_API_KEY>"
AI_INGEST_MAX_CANDIDATES_PER_VENUE_RUN="25"
AI_INGEST_DUPLICATE_SIMILARITY_THRESHOLD="85"
AI_INGEST_DUPLICATE_LOOKBACK_DAYS="30"
AI_INGEST_CONFIDENCE_HIGH_MIN="75"
AI_INGEST_CONFIDENCE_MEDIUM_MIN="45"
AI_INGEST_CRON_MAX_VENUES="10"
AI_INGEST_CRON_MAX_TOTAL_CREATED_CANDIDATES="100"
AI_INGEST_CRON_TIME_BUDGET_MS="120000"
AI_INGEST_CRON_CIRCUIT_BREAKER_WINDOW_HOURS="6"
AI_INGEST_CRON_CIRCUIT_BREAKER_MIN_RUNS="5"
AI_INGEST_CRON_CIRCUIT_BREAKER_FAIL_RATE="0.6"
# Required on Vercel builds to allow image import behavior.
AI_INGEST_IMAGE_ENABLED="1"
AI_INGEST_IMAGE_MAX_BYTES="5000000"

##############################
# Storage
##############################
BLOB_READ_WRITE_TOKEN="<VERCEL_BLOB_READ_WRITE_TOKEN>"

##############################
# Feature flags / testing
##############################
# Optional E2E test bypass; only honored outside production.
PLAYWRIGHT="false"
# Private beta controls (optional)
BETA_MODE="0"
BETA_ALLOWLIST="user1@example.com,user2@example.com"
BETA_ALLOW_DOMAINS="example.com"
BETA_ADMIN_EMAILS="admin@example.com"
BETA_REQUESTS_ENABLED="1"
